{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(cargo build:*)",
            "Bash(cargo clippy:*)",
            "Bash(cargo fmt:*)",
            "Bash(cargo test:*)",
            "Bash(cat:*)",
            "Bash(find:*)",
            "Bash(gh issue list:*)",
            "Bash(gh pr checks:*)",
            "Bash(gh pr diff:*)",
            "Bash(gh pr list:*)",
            "Bash(gh pr view:*)",
            "Bash(gh pr watch:*)",
            "Bash(gh run list:*)",
            "Bash(gh run view:*)",
            "Bash(go build:*)",
            "Bash(go doc:*)",
            "Bash(go list:*)",
            "Bash(go mod:*)",
            "Bash(go test:*)",
            "Bash(go vet:*)",
            "Bash(grep:*)",
            "Bash(head:*)",
            "Bash(jq:*)",
            "Bash(ls:*)",
            "Bash(tail:*)",
            "Bash(uv run ruff check:*)",
            "Bash(uv run ruff format:*)",
            "Bash(uv run ruff:*)",
            "Bash(uv sync:*)",
            "Bash(yq:*)",
            "mcp__filesystem__directory_tree",
            "mcp__filesystem__list_directory",
            "mcp__filesystem__read_multiple_files",
            "mcp__filesystem__read_text_file"
        ],
        "deny": [
            "Read(./.env)"
        ]
    },
    "enabledMcpjsonServers": [
        "postgres",
        "filesystem"
    ],
    "enabledPlugins": {
        "rust-analyzer-lsp@claude-plugins-official": true
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$HOME/.claude/hooks/conditional-format.sh",
                        "timeout": 5
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "npx -y ccstatusline@latest",
        "padding": 0
    }
}
